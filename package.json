{
  "name": "mujoco-react",
  "version": "10.7.0",
  "description": "Composable React Three Fiber building blocks for MuJoCo WASM simulations",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      }
    },
    "./spark": {
      "import": {
        "types": "./dist/spark.d.ts",
        "default": "./dist/spark.js"
      }
    },
    "./package.json": "./package.json",
    "./onnx": {
      "import": {
        "types": "./dist/onnx.d.ts",
        "default": "./dist/onnx.js"
      }
    }
  },
  "bin": {
    "mujoco-react": "./bin/mujoco-react.mjs",
    "mujoco-react-codegen": "./bin/mujoco-react-codegen.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "mujoco",
    "react",
    "three",
    "r3f",
    "react-three-fiber",
    "physics",
    "simulation",
    "robotics",
    "wasm"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noah-wardlow/mujoco-react.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9",
    "@react-three/fiber": ">=8",
    "@sparkjsdev/spark": ">=2.1.0",
    "react": ">=18",
    "three": ">=0.180.0",
    "onnxruntime-web": ">=1.20.0"
  },
  "peerDependenciesMeta": {
    "@sparkjsdev/spark": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "dependencies": {
    "@mujoco/mujoco": "^3.9.0"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@sparkjsdev/spark": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/three": "^0.181.0",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.2.0",
    "semantic-release": "^25.0.3",
    "three": "^0.181.0",
    "tsup": "^8.4.0",
    "typescript": "~5.8.2"
  }
}
